# Red de Esperanza — SQLite (desarrollo) o PostgreSQL (producción)
DATABASE_URL=sqlite+aiosqlite:///./red_esperanza.db
VICTIMS_DATABASE_URL=sqlite+aiosqlite:///./ojo_de_dios.db
VICTIMS_API_URL=https://desaparecidos-terremoto-api.theempire.tech/api
VICTIMS_SYNC_INTERVAL_SECONDS=20
VICTIMS_SYNC_MAX_PAGES=5
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/red_esperanza

HOST=0.0.0.0
PORT=8000
MATCH_THRESHOLD=0.55
MATCHER_INTERVAL_SECONDS=45
# PUBLIC_BASE_URL=https://tu-dominio.com

# Google Maps — Centro de Comando GIS
GOOGLE_MAPS_API_KEY=

# Redis opcional — broadcast WebSocket multi-instancia
REDIS_URL=

# Auth — cambiar JWT_SECRET en producción
JWT_SECRET=cambiar-en-produccion-red-esperanza-2026
SUPER_ADMIN_USERNAME=JOM
SUPER_ADMIN_PASSWORD=Studio

# Sync mapa Punto de Apoyo (segundos)
PUNTO_APOYO_SYNC_SECONDS=25
LIVE_SYNC_INTERVAL_SECONDS=0.25
PUNTO_APOYO_SUPABASE_KEY=

# Firebase — portal familiar (proyecto Esperanzavzla)
FIREBASE_PROJECT_ID=Esperanzavzla
FIREBASE_DATABASE_URL=https://esperanzavzla-default-rtdb.firebaseio.com
FIREBASE_API_KEY=
FIREBASE_APP_ID=1:192287687789:web:a376ad649a10a0bbe8ab64
FIREBASE_MESSAGING_SENDER_ID=192287687789
# Service account JSON (Firebase Console → Configuración → Cuentas de servicio)
FIREBASE_CREDENTIALS_PATH=